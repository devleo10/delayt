{
  "name": "delayt-backend",
  "version": "2.0.1",
  "private": true,
  "description": "Delayt API server",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "prebuild": "cd ../packages/shared && npm run build",
    "build": "tsc",
    "start": "node dist/server.js",
    "cli": "npm run build --prefix ../packages/cli 2>/dev/null || true; node ../packages/cli/dist/index.js"
  },
  "license": "MIT",
  "dependencies": {
    "@delayt/shared": "file:../packages/shared",
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.10.5",
    "@types/express": "^4.17.21",
    "@types/pg": "^8.10.9",
    "@types/cors": "^2.8.17",
    "ts-node-dev": "^2.0.0",
    "ts-node": "^10.9.2"
  }
}
