# Database (local Docker; use Neon pooled URL on Vercel)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/latency_db

# Production site URL (Vercel custom domain)
FRONTEND_URL=http://localhost:3000
# ALLOWED_ORIGINS=https://yourdomain.dev

# Web dashboard limits (server-enforced; UI uses same defaults)
WEB_DEFAULT_REQUEST_COUNT=15
WEB_MAX_REQUEST_COUNT=20

# Per-request timeout when hitting target APIs (lower on Vercel Hobby)
REQUEST_TIMEOUT_MS=15000
DEFAULT_REQUEST_COUNT=15

# Rate limiting (soft, in-memory on serverless)
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_MS=3600000

# Vercel production: set DATABASE_URL to Neon, FRONTEND_URL to https://yourdomain.dev
# See docs/vercel.md
