# Copy to deploy/.env.production on the server (never commit the real file)

POSTGRES_PASSWORD=change_me_to_a_long_random_string

# Canonical site URL (share links). Use www if that is your primary host.
FRONTEND_URL=https://www.delayt.foo

# CORS: list every browser origin users may open (apex + www if both work).
ALLOWED_ORIGINS=https://www.delayt.foo,https://delayt.foo

# Web dashboard limits (server-enforced)
WEB_DEFAULT_REQUEST_COUNT=15
WEB_MAX_REQUEST_COUNT=20

# Per-request timeout when hitting target APIs
REQUEST_TIMEOUT_MS=30000

# Rate limiting (soft, in-memory per instance)
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_MS=3600000

# Optional: require key for CLI --share uploads (set same value as DELAYT_IMPORT_API_KEY in CI)
IMPORT_API_KEY=
